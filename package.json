{
  "name": "blackbelt",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=18.17.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "setup": "pnpm install && echo '✅ Lock file gerado e dependências instaladas.'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit",
    "precommit": "lint-staged",
    "db:migrate": "npx ts-node server/src/infrastructure/database/migrate.ts",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down"
  },
  "dependencies": {
    "@capacitor/android": "8.1.0",
    "@capacitor/app": "8.0.1",
    "@capacitor/browser": "8.0.1",
    "@capacitor/cli": "8.1.0",
    "@capacitor/core": "8.1.0",
    "@capacitor/haptics": "8.0.1",
    "@capacitor/ios": "8.1.0",
    "@capacitor/keyboard": "8.0.1",
    "@capacitor/push-notifications": "8.0.1",
    "@capacitor/splash-screen": "8.0.1",
    "@capacitor/status-bar": "8.0.1",
    "@supabase/ssr": "0.8.0",
    "@supabase/supabase-js": "2.97.0",
    "dotenv": "^16.4.0",
    "jsqr": "1.4.0",
    "lucide-react": "^0.365.0",
    "next": "14.2.35",
    "pg": "^8.13.0",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^2.12.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "16.1.6",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.11.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.0.1",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.35",
    "eslint-plugin-unused-imports": "4.4.1",
    "husky": "^9.0.0",
    "jsdom": "^25.0.0",
    "lint-staged": "^15.0.0",
    "postcss": "^8",
    "sharp": "0.34.5",
    "supabase": "2.76.15",
    "tailwindcss": "^3.4.1",
    "tsx": "4.21.0",
    "typescript": "^5",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --no-warn-ignored",
      "bash -c \"tsc --noEmit\""
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@9.15.0"
}
