# ============================================================
# BLACKBELT — Environment Variables
# ============================================================
# Copy to .env.local: cp .env.example .env.local
#
# ⚠️ IMPORTANTE: Nunca comite arquivos .env.local para o git!
# ============================================================

# ── Data Source ──────────────────────────────────────────
# true  = Mock data (dev without backend)
# false = Real Supabase backend
NEXT_PUBLIC_USE_MOCK=true

# ── Supabase (REQUIRED for production) ──────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe Payments (REQUIRED for production) ────────────
# Get from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
# Webhook secret from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Stripe Plan Price IDs (REQUIRED for production) ────
# One env var per plan+cycle. resolveStripePriceId() tries:
#   STRIPE_PRICE_{ID}_{CYCLE}, STRIPE_PRICE_{NAME}_{CYCLE},
#   STRIPE_PRICE_{DISPLAY_NAME}_{CYCLE}
# Example for 3-tier model (Starter, Professional, Enterprise):
# STRIPE_PRICE_STARTER_MONTHLY=price_xxx
# STRIPE_PRICE_STARTER_ANNUAL=price_xxx
# STRIPE_PRICE_PROFESSIONAL_MONTHLY=price_xxx
# STRIPE_PRICE_PROFESSIONAL_ANNUAL=price_xxx
# STRIPE_PRICE_ENTERPRISE_MONTHLY=price_xxx
# STRIPE_PRICE_ENTERPRISE_ANNUAL=price_xxx

# ── Stripe PIX (Brazil only) ────────────────────────────
# Required for PIX payments in Brazil
# Configure at: https://dashboard.stripe.com/settings/payment_methods
STRIPE_PIX_ENABLED=true

# ── Sentry Error Tracking (Recommended for production) ───
# Get from: https://sentry.io/settings/projects/
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=sntrys_xxx
SENTRY_ORG=blackbelt
SENTRY_PROJECT=blackbelt-app

# ── Google Analytics 4 (Recommended for production) ─────
# Get from: https://analytics.google.com/analytics/web/
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Resend Email (REQUIRED for production) ──────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@blackbelt.app
RESEND_FROM_NAME=BlackBelt

# ── Database (optional, for event store) ────────────────
# DATABASE_URL=postgresql://user:pass@host:5432/blackbelt?sslmode=require

# ── Push Notifications ──────────────────────────────────
# FCM_SERVER_KEY=xxx

# ── External API (optional override) ────────────────────
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_APP_URL=https://app.blackbelt.com
# Optional override for the native shell. Defaults to NEXT_PUBLIC_APP_URL.
# Must be HTTPS in release builds.
# CAPACITOR_SERVER_URL=https://app.blackbelt.com
# Optional comma-separated fallback hosts for controlled runtime recovery.
# CAPACITOR_FALLBACK_URLS=https://app2.blackbelt.com,https://review.blackbelt.com
# Set to true only for temporary internal builds. Never use for store production.
# CAPACITOR_ALLOW_EPHEMERAL_HOST=false

# Public contacts used in runtime/compliance drafts
SUPPORT_EMAIL=suporte@blackbelt.app
PRIVACY_EMAIL=privacidade@blackbelt.app

# ── Security ────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# ENCRYPTION_KEY=hex-64-chars-aes-256
# SIEM_ENDPOINT=https://siem.example.com/api/events
# SIEM_API_KEY=xxx

# ── Seed Data (for npx tsx scripts/seed-all.ts) ────────
# SEED_ADMIN_EMAIL=admin@blackbelt.app
# SEED_PASSWORD=BlackBelt@2026!
