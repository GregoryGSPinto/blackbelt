# ============================================================
# BLACKBELT — Environment Variables
# ============================================================
# Copy to .env.local: cp .env.example .env.local

# ── Data Source ──────────────────────────────────────────
# true  = Mock data (dev without backend)
# false = Real Supabase backend
NEXT_PUBLIC_USE_MOCK=true

# ── Supabase (REQUIRED for production) ──────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Sentry (Recommended for production) ─────────────────
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_AUTH_TOKEN=sntrys_xxx
# SENTRY_ORG=blackbelt
# SENTRY_PROJECT=blackbelt-app

# ── Database (optional, for event store) ────────────────
# DATABASE_URL=postgresql://user:pass@host:5432/blackbelt?sslmode=require

# ── Push Notifications ──────────────────────────────────
# FCM_SERVER_KEY=xxx

# ── External API (optional override) ────────────────────
# NEXT_PUBLIC_API_URL=/api

# ── Security ────────────────────────────────────────────
# ENCRYPTION_KEY=hex-64-chars-aes-256
# SIEM_ENDPOINT=https://siem.example.com/api/events
# SIEM_API_KEY=xxx
