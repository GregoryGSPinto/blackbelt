# ============================================================
# BLACKBELT — Variáveis de Ambiente
# ============================================================

# ── Feature flag: Fonte de dados ──────────────────────────
# true  = Serviços retornam dados mock (dev sem backend)
# false = Serviços chamam API real
# (não definir = auto-detecta: dev sem API_URL → mock)
NEXT_PUBLIC_USE_MOCK=true

# ── Backend API ───────────────────────────────────────────
# Quando definido, desabilita mock automático e usa esta URL
# NEXT_PUBLIC_API_URL=http://localhost:8080/api

# ── Auth ──────────────────────────────────────────────────
# NEXT_PUBLIC_JWT_SECRET=your-secret-here

# ── Crash Reporting (Sentry) ─────────────────────────────
# Client-side (NEXT_PUBLIC_ = exposto no browser)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Server-side (nunca exposto)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_AUTH_TOKEN=sntrys_xxx
# SENTRY_ORG=blackbelt
# SENTRY_PROJECT=blackbelt-app

# ── Push Notifications (Firebase) ────────────────────────
# FCM_SERVER_KEY=xxx

# ── Supabase ─────────────────────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Database ─────────────────────────────────────────────
# DATABASE_URL=postgresql://user:pass@host:5432/blackbelt?sslmode=require

# ── Encryption ───────────────────────────────────────────
# ENCRYPTION_KEY=hex-64-chars-aes-256

# ── SIEM Integration ────────────────────────────────────
# SIEM_ENDPOINT=https://siem.example.com/api/events
# SIEM_API_KEY=xxx
