# ╔══════════════════════════════════════════════════════════════════╗
# ║  BLACKBELT — Variáveis de ambiente do servidor                   ║
# ╠══════════════════════════════════════════════════════════════════╣
# ║  Copie para .env e preencha os valores.                        ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Database ──────────────────────────────────────────────────────
# Local (Docker Compose):
# DATABASE_URL=postgresql://blackbelt:blackbelt@localhost:5432/blackbelt
#
# Supabase (produção):
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?sslmode=require
#
# Se não definir → sistema roda com Event Store em memória.

# DATABASE_URL=

# ── Server ────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug
